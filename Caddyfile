oc.nagaev.me {
    # Configure the DNS challenge via Cloudflare
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    # Route only /control (and anything under it like /control/assets) to port 18789
    handle /control* {
        reverse_proxy 127.0.0.1:18789
    }

    # OpenCode web UI → port 4096
    handle_path /opencode* {
        reverse_proxy 127.0.0.1:4096
    }

    # Fallback: Handle everything else with a 404 error
    handle {
        root * /usr/share/caddy

        # Bulletproof matcher: Must NOT be the root path, and the file must NOT exist
        @not_found {
            not path /
            not file {path} {path}/
        }
        redir @not_found / 302

        file_server
    }
}
